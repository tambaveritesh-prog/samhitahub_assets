# Copy this file to `.env` for local development.
# In staging/production, set these as real environment variables /
# secrets instead of shipping a `.env` file.

# --- General -----------------------------------------------------------
APP_NAME="SamhitaHub Studio Backend"
APP_VERSION=0.1.0
ENVIRONMENT=local            # local | development | staging | production | test
DEBUG=true

# --- API -----------------------------------------------------------------
API_V1_PREFIX=/api/v1
DOCS_ENABLED=true

# --- Server ----------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# --- CORS ------------------------------------------------------------------
# Comma-separated list of allowed origins, e.g.:
# CORS_ALLOW_ORIGINS=https://studio.samhitahub.app,http://localhost:3000
CORS_ALLOW_ORIGINS=*

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=false                # true in staging/production

# --- Security (placeholder, used once auth is implemented) -----------------
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Google Drive integration (placeholder, unused until implemented) ------
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# --- Firestore integration (placeholder, unused until implemented) ---------
FIRESTORE_PROJECT_ID=
FIRESTORE_CREDENTIALS_PATH=

# --- AI provider integration (placeholder, unused until implemented) -------
AI_PROVIDER_API_KEY=
AI_PROVIDER_MODEL=claude-sonnet-5
